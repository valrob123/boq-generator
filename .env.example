# Firebase web configuration for BOQ Builder (cloud sign-in + backup).
# Copy this file to ".env" (same folder as package.json) and fill in the
# values from your Firebase console: Project settings > General > Your apps.
#
# These VITE_* values are inlined into the client bundle at build time, so they
# are NOT secret — that is expected for Firebase. Protect your data with
# Firebase Authentication + Firestore Security Rules (see README), not by hiding
# these keys. Rebuild the app after editing this file.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Optional — enables an in-app "redeem activation code" to grant Pro without a
# payment processor (desktop license-key style). Leave blank to hide that field.
# For a REAL paid wall, flip the plan server-side (Stripe webhook); see README.
VITE_PRO_ACTIVATION_CODE=

# Admin allowlist — comma-separated emails that always get full Pro access and
# skip the promo wall (e.g. you). Case-insensitive.
VITE_ADMIN_EMAILS=
