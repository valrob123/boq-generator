{
  "name": "boq-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Bill of Quantities (BOQ) Builder — Philippine DPWH/DOH-compliant desktop application.",
  "author": "Engr. Robert",
  "license": "UNLICENSED",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k -n VITE,ELECTRON -c green,blue \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "firebase": "^12.14.0",
    "html2pdf.js": "0.10.3",
    "lucide-react": "0.471.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "electron": "33.3.1",
    "electron-builder": "25.1.8",
    "vite": "6.0.7",
    "wait-on": "8.0.1"
  },
  "build": {
    "appId": "ph.gov.boqbuilder",
    "productName": "BOQ Builder",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
